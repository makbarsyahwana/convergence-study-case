    {
      "name": "8. CMS Sync",
      "item": [
        {
          "name": "Webhook — create premium article",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/cms-sync/webhook", "host": ["{{baseUrl}}"], "path": ["cms-sync", "webhook"] },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-strapi-event", "value": "entry.create" }
            ],
