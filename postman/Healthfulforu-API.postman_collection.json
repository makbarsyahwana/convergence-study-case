    {
      "name": "5. Content — Gating Scenarios",
      "description": "Tests premium content access with different user roles. Run the Auth folder first to populate tokens.",
      "item": [
        {
          "name": "Free user reads premium content → gated",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/content/{{premiumSlug}}", "host": ["{{baseUrl}}"], "path": ["content", "{{premiumSlug}}"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{freeToken}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Content IS gated for free user', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json._gated).to.eql(true);",
                  "  pm.expect(json.body).to.be.null;",
                  "  pm.expect(json.videoUrl).to.be.null;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Premium user reads premium content → full access",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/content/{{premiumSlug}}", "host": ["{{baseUrl}}"], "path": ["content", "{{premiumSlug}}"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{premiumToken}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Content NOT gated for premium user', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json._gated).to.eql(false);",
                  "  pm.expect(json.body).to.not.be.null;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Admin reads premium content → full access",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/content/{{premiumSlug}}", "host": ["{{baseUrl}}"], "path": ["content", "{{premiumSlug}}"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Content NOT gated for admin', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json._gated).to.eql(false);",
                  "  pm.expect(json.body).to.not.be.null;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Free user reads free content → full access",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/content/{{freeSlug}}", "host": ["{{baseUrl}}"], "path": ["content", "{{freeSlug}}"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{freeToken}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Free content is accessible to free user', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json._gated).to.eql(false);",
                  "  pm.expect(json.body).to.not.be.null;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
