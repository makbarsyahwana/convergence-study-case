{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": false
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "body": {
      "type": "blocks"
    },
    "excerpt": {
      "type": "text"
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "ARTICLE",
        "VIDEO"
      ]
    },
    "isPremium": {
      "type": "boolean",
      "default": false
    },
    "thumbnailUrl": {
      "type": "string"
    },
    "videoUrl": {
      "type": "string"
    },
    "readTimeMinutes": {
      "type": "integer"
    }
  }
}
